generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model otp {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  otpHash      String
  expiresAt    DateTime


  // 2. Personal Details
  gender        Gender
  age           Int
  maritalStatus MaritalStatus

  // 3. Location
  areaType AreaType
  state    String

  // 4. Category & Disability
  socialCategory     SocialCategory
  isPwD              Boolean
  disabilityType     String?
  disabilityPercentage Int?

  // 5. Economic Profile
  occupation   Occupation
  isBPL        Boolean
  annualIncome IncomeRange


  createdAt DateTime @default(now())
}

model User {
  id String @id @default(uuid())

  // 1. Account Credentials
  email    String @unique
  password String

  // 2. Personal Details
  gender        Gender
  age           Int
  maritalStatus MaritalStatus

  // 3. Location
  areaType AreaType
  state    String

  // 4. Category & Disability
  socialCategory     SocialCategory
  isPwD              Boolean
  disabilityType     String?
  disabilityPercentage Int?

  // 5. Economic Profile
  occupation   Occupation
  isBPL        Boolean
  annualIncome IncomeRange

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  savedSchemes SavedSchemes[]
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum AreaType {
  URBAN
  RURAL
  SEMI_URBAN
}

enum SocialCategory {
  GENERAL
  OBC
  SC
  ST
  OBC_NCL
  EWS
}

enum Occupation {
  STUDENT
  FARMER
  SALARIED_EMPLOYEE
  SELF_EMPLOYED
  BUSINESS_OWNER
  DAILY_WAGE_WORKER
  HOMEMAKER
  SENIOR_CITIZEN
  UNEMPLOYED
  OTHER
}

enum IncomeRange {
  BELOW_1_LAKH
  BETWEEN_1_TO_3_LAKH
  BETWEEN_3_TO_5_LAKH
  BETWEEN_5_TO_10_LAKH
  ABOVE_10_LAKH
}


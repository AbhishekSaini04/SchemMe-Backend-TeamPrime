generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model otp {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  rollNo       String   @default("24001001901")
  mobile       String   @default("24001001901")
  branch       String   @default("CSE")
  college      String   @default("DCRUST")
  semester     Int      @default(1)
  passwordHash String
  otpHash      String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model user {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String   @default("")
  gender    String   @default("")
  category  String   @default("")
  isEWS     Boolean  @default(false)
  isPWD     Boolean  @default(false)
  ISBPL     Boolean  @default(false)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  FARMER
  STUDENT
  GOVERNMENT_EMPLOYEE
  PRIVATE_EMPLOYEE
  DAILY_WAGER
  UNEMPLOYED
  SELF_EMPLOYED
  DEFENSE_PERSONNEL
}
model Scheme {
  id              Int     @id @default(autoincrement())
  scheme_name     String
  slug            String?
  details         String?
  benefits        String?
  eligibility     String?
  application     String?
  documents       String?
  level           String?
  schemeCategory  String?
  tags            String?
  level_name      String?
  search_tags     String?
}